// Deliverables Dashboard — data model
// Dev DB: SQLite (zero external setup). Enum-typed fields are stored as String
// because SQLite has no native enums; the allowed values live in
// src/lib/constants.ts. For production, switch the datasource to postgresql and
// promote the String fields to real Prisma enums.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id        String    @id @default(cuid())
  name      String    @unique
  notes     String?
  portalId  String?   @unique //                 opt-in public client portal token
  // Seam 1 (Phase 1): annotation onto the LinkSpy registry. Nullable; unset =
  // exactly today's behaviour. Never mutates any existing QA field.
  registryClientId String?
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  name      String
  type      String   @default("WEBSITE") // ProjectType
  platform  String   @default("OTHER") //   Platform
  url       String?
  status    String   @default("IN_PROGRESS") // Status
  pages     Page[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Page {
  id            String         @id @default(cuid())
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  name          String
  url           String?
  status        String         @default("IN_PROGRESS") // Status
  shareId       String?        @unique //                 public certificate link token (opt-in)
  developer     TeamMember?    @relation("Dev", fields: [developerId], references: [id], onDelete: SetNull)
  developerId   String?
  tester        TeamMember?    @relation("Tester", fields: [testerId], references: [id], onDelete: SetNull)
  testerId      String?
  delayDays     Int            @default(0)
  deliveryMonth String? //                              "2026-01" — powers monthly report
  // Seam 1 (Phase 1): registry annotation. Nullable; unset = today's behaviour.
  registryDeliverableId String? //                      the LinkSpy deliverable id
  registrySiteId        String? //                      the LinkSpy site id
  issues        Issue[]
  certificate   QACertificate?
  linkspyStatus LinkSpyStatus?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@index([deliveryMonth])
}

// "Still True Today" — cache + durable last-known-good for a page's live
// verification status pulled from LinkSpy. Read-only mirror; internal-only
// (never selected by the public certificate / client-portal views).
model LinkSpyStatus {
  id        String   @id @default(cuid())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId    String   @unique
  payload   Json //     the raw /api/qa-bridge/status response
  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Issue {
  id          String   @id @default(cuid())
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId      String
  title       String
  description String?
  severity    String   @default("LOW") // Severity
  status      String   @default("OPEN") // IssueStatus
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pageId])
}

model TeamMember {
  id          String   @id @default(cuid())
  name        String   @unique
  role        String   @default("DEVELOPER") // MemberRole
  active      Boolean  @default(true)
  devPages    Page[]   @relation("Dev")
  testerPages Page[]   @relation("Tester")
  createdAt   DateTime @default(now())
}

model QACertificate {
  id          String        @id @default(cuid())
  page        Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId      String        @unique
  status      String        @default("IN_PROGRESS") // CertStatus
  testerName  String?
  completedAt DateTime?
  items       QACheckItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model QACheckItem {
  id            String        @id @default(cuid())
  certificate   QACertificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  certificateId String
  category      String //        Performance | Functional | Tracking | UX | Conversion Goals
  name          String
  result        String        @default("NA") // CheckResult
  valueDesktop  String?
  valueMobile   String?
  hasDualValue  Boolean       @default(false) // Desktop + Mobile inputs (browser tests, PageSpeed)
  isMeasurement Boolean       @default(false) // free-text value (load time, page size)
  notes         String?
  order         Int           @default(0)
  // Phase 3 (machine pre-fill + provenance). machine* are set only by the
  // human-confirm action (NEVER by background code — T4). confirmedSource records
  // whether a value was a human call or a confirmed machine result.
  machineVerdict  String? //   holding | failing | couldnt_verify (from qa_prefills)
  machineDetail   String?
  machineCheckedAt DateTime?
  confirmedSource String? //   'machine' | 'human'
  confirmedBy     String?
  confirmedAt     DateTime?

  @@index([certificateId])
}

// Reusable QA checklist templates. New certificates seed their items from the
// matching template (by platform) or the default; falls back to the built-in
// QA_TEMPLATE when none exist.
model ChecklistTemplate {
  id        String                  @id @default(cuid())
  name      String
  platform  String? //                 null = applies to any platform
  isDefault Boolean                 @default(false)
  items     ChecklistTemplateItem[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model ChecklistTemplateItem {
  id            String            @id @default(cuid())
  template      ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId    String
  category      String
  name          String
  hasDualValue  Boolean           @default(false)
  isMeasurement Boolean           @default(false)
  order         Int               @default(0)
  // Flywheel (Phase 5): provenance for items born from a production incident.
  // Nullable; unset = a normal template item. Set only by the promote action.
  origin        String? //   'flywheel' when added from a production incident
  originAt      DateTime?

  @@index([templateId])
}

// Flywheel (Phase 5): production incidents that had no delivery check arrive here
// as candidates for human review. Own table; the human PROMOTE action is the ONLY
// writer of ChecklistTemplateItem (T4). Additive.
model ChecklistCandidate {
  id                  String    @id @default(cuid())
  linkspyCandidateRef String    @unique //   idempotency key for the inbox
  incidentClass       String
  proposedWording     String
  evidence            Json
  machineVerifiable   Boolean   @default(false)
  status              String    @default("draft") // draft | promoted | dismissed
  rationale           String? //   mandatory at promote-time (server-enforced)
  reason              String? //   optional dismiss reason
  decidedBy           String?
  decidedAt           DateTime?
  createdAt           DateTime  @default(now())

  @@index([status])
}

// Spine outbox (Phase 2 Seam 2): events written in the SAME transaction as the
// status change that produced them, drained to LinkSpy. Additive; emission is
// gated by SPINE_EMIT (unset = today's behaviour, no rows).
model SpineOutbox {
  id                    String    @id @default(cuid())
  type                  String
  payload               Json
  registryDeliverableId String?
  registrySiteId        String?
  occurredAt            DateTime  @default(now())
  deliveredAt           DateTime?
  attempts              Int       @default(0)
  lastError             String?
  createdAt             DateTime  @default(now())

  @@index([deliveredAt])
}
