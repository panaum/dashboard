# Copy to .env and fill in. Placeholders only — never commit real values.
DATABASE_URL=""        # Supabase pooled connection (port 6543, pgbouncer)
DIRECT_URL=""          # Supabase direct connection (port 5432) — migrations / import
APP_PASSWORD="change-me"
AUTH_SECRET="generate-a-long-random-string"
ANTHROPIC_API_KEY=""   # optional — enables Claude QA judgment
E2E_PASSWORD="change-me"  # Playwright login; must equal the server's APP_PASSWORD

# "Still True Today" — live verification status from LinkSpy (optional; feature
# is silent when unset). Read server-side only; the key never reaches the client.
LINKSPY_API_URL=""     # LinkSpy backend base, e.g. https://linkspy-api.example.com
LINKSPY_API_KEY=""     # QA-bridge service key (create in LinkSpy: Site → Settings → QA Dashboard link)
LINKSPY_APP_URL=""     # optional — LinkSpy dashboard base for deep links, e.g. https://linkspy.example.com
